@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<link href="/css/footer.css" rel="stylesheet" />

<AuthorizeView>
    <Authorized>
        <div class="page">
            <div class="sidebar">
                <NavMenu />
            </div>

            <main>
                <div class="top-row px-4 d-flex justify-content-end align-items-center">
                    <LocationSelector />
                    <ProfileDropdown />
                </div>

                <article class="content px-4">
                    @Body
                </article>
            </main>
            <div class="feedback-fixed">
                <FeedbackButton />
            </div>
            <footer class="footer">
                <img src="/images/cc_favicon_green_clear2.png" alt="Culinary Command Logo" class="footer-logo" />
                <span class="footer-text">&copy; @DateTime.Now.Year Culinary Command. All rights reserved.</span>
                <div class="footer-links">
                    <a href="https://github.com/Culinary-Command/CulinaryCommand" target="_blank"
                       rel="noopener">GitHub</a>
                    <a href="/privacy">Privacy Policy</a>
                    <a href="/contact">Contact</a>
                </div>
            </footer>
        </div>
    </Authorized>

    <NotAuthorized>
        <main class="public-page">
            @Body
        </main>
        <footer class="footer">
            <img src="/images/cc_favicon_green_clear2.png" alt="Culinary Command Logo" class="footer-logo" />
            <span class="footer-text">&copy; @DateTime.Now.Year Culinary Command. All rights reserved.</span>
            <div class="footer-links">
                <a href="https://github.com/ryanrockey/CulinaryCommand" target="_blank" rel="noopener">GitHub</a>
                <a href="/privacy">Privacy Policy</a>
                <a href="/contact">Contact</a>
            </div>
        </footer>
    </NotAuthorized>
</AuthorizeView>
