@page "/"
@page "/welcome"
@namespace CulinaryCommand.Components.Layout
@layout CulinaryCommand.Components.Layout.PublicLayout


<PageTitle>Culinary Command - Product Overview</PageTitle>

<div class="welcome">
    <nav class="welcome-nav">
        <div class="nav-brand">
            <button type="button" style="background:none;border:none;padding:0;cursor:pointer;" onclick="window.scrollTo({top:0,behavior:'smooth'})">
                <img src="/images/logos/mascot-logo.png" alt="Culinary Command" style="height:48px;" />
            </button>
        </div>
        <div class="nav-pill">
            <a class="active" href="#features">Features</a>
            <a href="#how">How It Works</a>
            <a href="#pricing">Pricing</a>
            <a href="#faq">About</a>
        </div>
        <a class="btn-cta" href="/account">Get Started <i class="bi bi-arrow-right"></i></a>
    </nav>

    <section class="hero-banner">
        <div class="hero-content">
            <div class="hero-left">
                <div class="hero-kicker">Restaurant Back-of-House Task Management System</div>
                <div class="hero-badge">
                    <span class="badge-dot"></span>
                    Built for small restaurant teams
                </div>
                <h1 class="hero-title">
                    Run Your Kitchen Like a System<br />
                    <span class="hero-title-accent">Not a Scramble</span>
                </h1>
                <p class="hero-description">
                    Culinary Command helps small restaurants manage prep tasks, inventory, ordering, recipes, and employee workflows in one organized platform.
                </p>
                <p class="hero-proof">Designed and tested around real back-of-house workflows from small restaurants.</p>
                <div class="hero-buttons">
                    <a class="btn-primary" href="/account">Get Started</a>
                    <a class="btn-secondary" href="#features">
                        <i class="bi bi-grid-1x2-fill"></i>
                        View Features
                    </a>
                </div>
            </div>
            <div class="hero-right">
                <div class="hero-image-container">
                    <img src="https://images.unsplash.com/photo-1577219491135-ce391730fb2c?q=80&w=2000&auto=format&fit=crop" 
                         alt="Professional commercial kitchen with industrial equipment" 
                         class="hero-food-image" />
                    <div class="image-overlay">
                        <div class="overlay-stat">
                            <i class="bi bi-list-check"></i>
                            <div>
                                <div class="stat-number">Prep Tasks</div>
                                <div class="stat-text">Assigned by shift</div>
                            </div>
                        </div>
                        <div class="overlay-stat">
                            <i class="bi bi-box-seam"></i>
                            <div>
                                <div class="stat-number">Inventory</div>
                                <div class="stat-text">Par + count tracking</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="trust-strip">
        <div class="trust-item">
            <i class="bi bi-shop"></i>
            <span>Built for <strong>small restaurant teams</strong></span>
        </div>
        <div class="trust-item">
            <i class="bi bi-geo-alt-fill"></i>
            <span>Tested with <strong>Prairie Canary</strong> and <strong>Hometown Heroes</strong> workflows</span>
        </div>
    </section>

    <section class="welcome-section" id="features">
        <div class="features-header">
            <h2 class="features-title">Full Visibility Across Every Station</h2>
            <p class="features-subtitle">Coordinate prep, inventory, employee execution, and planning in one platform built around practical kitchen workflows.</p>
        </div>
        <div class="feature-grid">
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="bi bi-list-check"></i>
                </div>
                <h3 class="feature-title">Prep Task Assignment</h3>
                <p class="feature-description">Assign prep and operational work by shift so the kitchen knows what needs to happen and when.</p>
                <div class="feature-progress"></div>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="bi bi-person-badge"></i>
                </div>
                <h3 class="feature-title">Employee My Tasks View</h3>
                <p class="feature-description">Give each employee a focused task view with assignment status, prep context, and completion history.</p>
                <div class="feature-progress"></div>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="bi bi-box-seam"></i>
                </div>
                <h3 class="feature-title">Inventory Par + Count</h3>
                <p class="feature-description">Track inventory against par levels and current counts so shortages and prep gaps are easier to catch early.</p>
                <div class="feature-progress"></div>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="bi bi-cart-check"></i>
                </div>
                <h3 class="feature-title">Ordering Support</h3>
                <p class="feature-description">Spot missing ingredients and organize ordering decisions with clearer visibility into what the kitchen needs next.</p>
                <div class="feature-progress"></div>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="bi bi-journal-text"></i>
                </div>
                <h3 class="feature-title">Recipe Integration</h3>
                <p class="feature-description">Connect prep work to recipe details so staff can move from assigned task to recipe guidance without switching systems.</p>
                <div class="feature-progress"></div>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="bi bi-stars"></i>
                </div>
                <h3 class="feature-title">AI Smart Task Planning</h3>
                <p class="feature-description">Use Gemini-powered planning to help generate smarter prep suggestions based on workload and inventory context.</p>
                <div class="feature-progress"></div>
            </div>
        </div>
    </section>

    <section class="welcome-section" id="how">
        <div class="features-header">
            <h2 class="features-title">How Culinary Command Works</h2>
            <p class="features-subtitle">A simple operational flow connects managers, kitchen staff, and system data in one coordinated workflow.</p>
        </div>
        <div class="steps">
            <div class="step-card">
                <div class="step-number-badge">01</div>
                <div class="step-icon">
                    <i class="bi bi-people-fill"></i>
                </div>
                <h3 class="step-title">Manager Layer</h3>
                <p class="step-description">Managers assign tasks, set prep lists, and monitor kitchen operations.</p>
            </div>
            <div class="step-card">
                <div class="step-number-badge">02</div>
                <div class="step-icon">
                    <i class="bi bi-diagram-3-fill"></i>
                </div>
                <h3 class="step-title">Application Logic</h3>
                <p class="step-description">Culinary Command coordinates tasks, inventory, and workflows in real time.</p>
            </div>
            <div class="step-card">
                <div class="step-number-badge">03</div>
                <div class="step-icon">
                    <i class="bi bi-database-fill"></i>
                </div>
                <h3 class="step-title">Data Layer</h3>
                <p class="step-description">All data is stored and synced across the system for consistency and tracking.</p>
            </div>
        </div>
    </section>

    <section class="welcome-section ai-callout-section">
        <div class="ai-callout-card">
            <div class="ai-callout-icon">
                <i class="bi bi-stars"></i>
            </div>
            <div>
                <div class="ai-callout-label">AI Highlight</div>
                <h3>AI-Powered Smart Task Planning</h3>
                <p>Gemini helps generate prep plans based on workload, staffing context, and inventory conditions so kitchens can respond faster during service.</p>
            </div>
        </div>
    </section>

    <section class="welcome-section pricing-section" id="pricing">
        <div class="features-header">
            <h2 class="features-title">Plans for Different Kitchen Needs</h2>
            <p class="features-subtitle">Choose the level of back-of-house coordination that fits your team, workflows, and growth stage.</p>
        </div>
        <div class="pricing-grid">
            <div class="pricing-card">
                <div class="pricing-header">
                    <h3 class="pricing-title">Starter</h3>
                    <div class="price-copy">For small kitchens getting organized</div>
                </div>
                <ul class="pricing-features">
                    <li><i class="bi bi-check-circle-fill"></i> Prep task lists</li>
                    <li><i class="bi bi-check-circle-fill"></i> Basic inventory tracking</li>
                    <li><i class="bi bi-check-circle-fill"></i> Employee task view</li>
                </ul>
                <a class="btn-ghost" href="/account">Get Started</a>
            </div>
            <div class="pricing-card featured">
                <div class="featured-tag">Most Popular</div>
                <div class="pricing-header">
                    <h3 class="pricing-title">Restaurant</h3>
                    <div class="price-copy">For full back-of-house management</div>
                </div>
                <ul class="pricing-features">
                    <li><i class="bi bi-check-circle-fill"></i> Task assignment by employee</li>
                    <li><i class="bi bi-check-circle-fill"></i> Recipe-linked prep work</li>
                    <li><i class="bi bi-check-circle-fill"></i> Inventory and order tracking</li>
                    <li><i class="bi bi-check-circle-fill"></i> AI smart task planning</li>
                </ul>
                <a class="btn-primary" href="#features">View Features</a>
            </div>
            <div class="pricing-card">
                <div class="pricing-header">
                    <h3 class="pricing-title">Multi-Location</h3>
                    <div class="price-copy">For growing restaurant groups</div>
                </div>
                <ul class="pricing-features">
                    <li><i class="bi bi-check-circle-fill"></i> Multiple locations</li>
                    <li><i class="bi bi-check-circle-fill"></i> Shared recipes and workflows</li>
                    <li><i class="bi bi-check-circle-fill"></i> Location-based employees</li>
                    <li><i class="bi bi-check-circle-fill"></i> Scalable operations</li>
                </ul>
                <a class="btn-ghost" href="#footer-project">Contact Team</a>
            </div>
        </div>
    </section>

    <section class="welcome-section" id="faq">
        <div class="features-header">
            <h2 class="features-title">Frequently Asked Questions</h2>
            <p class="features-subtitle">A quick overview of what Culinary Command does and where it fits in a restaurant workflow.</p>
        </div>
        <div class="faq-grid">
            <div class="faq-card">
                <div class="faq-icon">
                    <i class="bi bi-people-fill"></i>
                </div>
                <h3 class="faq-title">Who is Culinary Command for?</h3>
                <p class="faq-description">It is built for small restaurant teams that need more structure around prep, inventory, and employee coordination.</p>
            </div>
            <div class="faq-card">
                <div class="faq-icon">
                    <i class="bi bi-ui-checks-grid"></i>
                </div>
                <h3 class="faq-title">How is this different from a basic task app?</h3>
                <p class="faq-description">Culinary Command connects tasks to kitchen workflows like prep, recipes, inventory status, and shift-level execution.</p>
            </div>
            <div class="faq-card">
                <div class="faq-icon">
                    <i class="bi bi-building-check"></i>
                </div>
                <h3 class="faq-title">Does it support multiple locations?</h3>
                <p class="faq-description">Yes. The platform is designed to scale from a single kitchen to multiple restaurant locations.</p>
            </div>
            <div class="faq-card">
                <div class="faq-icon">
                    <i class="bi bi-stars"></i>
                </div>
                <h3 class="faq-title">How does AI help kitchens?</h3>
                <p class="faq-description">Gemini is used to support smart task planning so teams can make prep decisions with better context.</p>
            </div>
            <div class="faq-card">
                <div class="faq-icon">
                    <i class="bi bi-tools"></i>
                </div>
                <h3 class="faq-title">What problems does it solve?</h3>
                <p class="faq-description">It reduces scramble around prep work, improves task visibility, and helps kitchens stay more organized during service.</p>
            </div>
        </div>
    </section>

    <section class="welcome-section tech-section">
        <div class="features-header">
            <h2 class="features-title">Built with Modern Technology</h2>
            <p class="features-subtitle">A practical stack for real-time operations, structured data, and intelligent planning.</p>
        </div>
        <div class="tech-grid">
            <div class="tech-card"><span>Frontend</span><strong>Blazor Server</strong></div>
            <div class="tech-card"><span>Backend</span><strong>ASP.NET Core</strong></div>
            <div class="tech-card"><span>ORM</span><strong>Entity Framework Core</strong></div>
            <div class="tech-card"><span>Database</span><strong>MySQL</strong></div>
            <div class="tech-card"><span>Hosting</span><strong>AWS EC2, RDS, S3</strong></div>
            <div class="tech-card"><span>AI Integration</span><strong>Gemini API</strong></div>
        </div>
    </section>



    <footer class="welcome-footer" id="footer-project">
        <div class="footer-content">
            <div class="footer-brand">
                <div class="footer-logo">
                    <i class="bi bi-x-diamond-fill"></i>
                    <span>CULINARY COMMAND</span>
                </div>
                <p class="footer-tagline">
                    Back-of-house task management for small restaurant teams.
                </p>
            </div>

            <div class="footer-links">
                <div class="footer-column">
                    <h4>Product</h4>
                    <ul>
                        <li><a href="#features">Task Management</a></li>
                        <li><a href="#features">Inventory Tracking</a></li>
                        <li><a href="#features">Recipe Management</a></li>
                        <li><a href="#features">AI Planning</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h4>Project</h4>
                    <ul>
                        <li><a href="#how">About</a></li>
                        <li><a href="https://sdmay26-44.sd.ece.iastate.edu/#teammembers" target="_blank" rel="noopener">Meet the Team</a></li>
                        <li><a href="https://github.com/Culinary-Command/CulinaryCommand" target="_blank" rel="noopener">GitHub</a></li>
                        <li><a href="https://sdmay26-44.sd.ece.iastate.edu/" target="_blank" rel="noopener">Team Website</a></li>
                        <li><a href="mailto:culinarycommand44@gmail.com">Contact</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <p>© 2026 Culinary Command. All rights reserved.</p>
        </div>
    </footer>
</div>
